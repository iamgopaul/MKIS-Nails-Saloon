# ── Supabase ─────────────────────────────────────────────────────────────────
# From: supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key
# service_role (secret) key — bypasses RLS, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Gmail SMTP (booking confirmation emails) ─────────────────────────────────
# Use a Google App Password — NOT your regular Gmail password
# Enable at: myaccount.google.com → Security → 2-Step Verification → App Passwords
SMTP_USER=mkisservicesllc@gmail.com
SMTP_PASS=your_16_char_google_app_password

# ── Telegram Bot (booking notifications to admin) ────────────────────────────
# 1) Message @BotFather → /newbot → copy the token
# 2) Aunt sends a message to the bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates → copy chat.id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Groq (Bella chatbot) ─────────────────────────────────────────────────────
# Sign up at console.groq.com → API Keys → Create
GROQ_API_KEY=your_groq_api_key

# ── Site URL (used for OG image metadata + invite redirect) ──────────────────
# Production: https://yourdomain.com — Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://mkisnails.com

# ── Admin URL (subdomain that hosts the admin/team dashboard) ────────────────
# Production: https://admin.yourdomain.com — Local dev: http://admin.localhost:3000
# Middleware redirects /admin* off the main site to this host, and blocks
# non-admin paths on this host from leaking the public marketing site.
NEXT_PUBLIC_ADMIN_URL=https://admin.mkisnails.com

# ── Cron secret (Vercel Cron + Supabase pg_cron) ─────────────────────────────
# Any random string — Vercel sends it as `Authorization: Bearer <secret>`
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Sentry (error tracking) ──────────────────────────────────────────────────
# DSN is public — find at: sentry.io → Settings → Projects → [proj] → Client Keys
# Server config falls back to NEXT_PUBLIC_SENTRY_DSN, so one var is enough.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Source map upload at build time (optional but recommended).
# Generate a token at https://sentry.io/settings/auth-tokens/ with scopes:
# project:releases, org:read
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
